# SSC MTS AUTO EXAM GENERATOR - Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=ssc_mts_exam_db
MONGODB_QUESTIONS_COLLECTION=questions
MONGODB_PAPERS_COLLECTION=papers
MONGODB_USERS_COLLECTION=users

# ==========================================
# API CONFIGURATION
# ==========================================

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_DEBUG=True

# JWT
JWT_SECRET_KEY=your_super_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==========================================
# AI/ML CONFIGURATION
# ==========================================

# OpenAI API
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ==========================================
# FILE STORAGE
# ==========================================

DATA_DIR=data/
PAPERS_DIR=data/raw_papers/
EXTRACTED_DIR=data/extracted_questions/
GENERATED_DIR=data/generated_questions/
TESTS_DIR=data/mock_tests/

# ==========================================
# WEB SCRAPING
# ==========================================

CHROME_DRIVER_PATH=./chromedriver
BROWSER_TIMEOUT=30

# ==========================================
# LOGGING
# ==========================================

LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==========================================
# FEATURES FLAGS
# ==========================================

ENABLE_AI_GENERATION=True
ENABLE_OCR=True
ENABLE_AUTO_SCRAPER=False
ENABLE_PDF_EXPORT=True

# ==========================================
# QUESTION GENERATION SETTINGS
# ==========================================

# Difficulty distribution
EASY_PERCENTAGE=33
MEDIUM_PERCENTAGE=34
HARD_PERCENTAGE=33

# Questions per set
MATHS_QUESTIONS=25
REASONING_QUESTIONS=25
GK_QUESTIONS=25
ENGLISH_QUESTIONS=25

# ==========================================
# SESSION CONFIGURATION
# ==========================================

SESSION_1_NEGATIVE_MARKING=0
SESSION_2_NEGATIVE_MARKING=1
SESSION_1_DURATION=120
SESSION_2_DURATION=120
